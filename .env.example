# ─────────────────────────────────────────────────────────────────────────────
# DFIR-FENRIR v2 — Environment Configuration
# Copy to .env and fill in real values. NEVER commit .env to Git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
POSTGRES_PASSWORD=change_me_strong_password_here

# ── Redis ─────────────────────────────────────────────────────────────────────
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
REDIS_PASSWORD=change_me_redis_password

# ── Application secret ────────────────────────────────────────────────────────
# Generate: python3 -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=change_me_generate_64_char_hex_secret

# ── TLS / Domain ──────────────────────────────────────────────────────────────
# Caddy selects TLS mode automatically based on what is set here.
#
# Mode A — Self-signed (default, no setup needed):
#   DOMAIN=localhost   (local access only — leave everything else blank)
#   DOMAIN=192.168.x.x (to access from other machines on the network, use the server's IP)
#
# Mode B — Let's Encrypt via DuckDNS (automatic cert, port 80 not required):
#   DOMAIN=yourname.duckdns.org
#   LETSENCRYPT_EMAIL=you@example.com
#   DUCKDNS_TOKEN=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
#
# Mode C — Bring your own certificate (place files in certs/):
#   DOMAIN=fenrir.yourdomain.com
#   TLS_CERT_FILE=/certs/server.crt
#   TLS_KEY_FILE=/certs/server.key
#
DOMAIN=localhost
LETSENCRYPT_EMAIL=
DUCKDNS_TOKEN=
TLS_CERT_FILE=
TLS_KEY_FILE=

# ── Network access ────────────────────────────────────────────────────────────
# CORS_ORIGINS: which browser origins can make API requests.
# ALLOWED_HOSTS: which Host headers the backend accepts.
CORS_ORIGINS=https://localhost
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Auth policy ──────────────────────────────────────────────────────────────
# TOTP_REQUIRED=true  → first-run admin + admin-created users are forced
#                       through TOTP enrolment before reaching the app.
# TOTP_REQUIRED=false → TOTP becomes opt-in. Users enrol from Settings
#                       (or the /totp/enrol route) on their own schedule.
# Default = true. Leave on unless you have a specific reason. Disabling 2FA
# materially weakens the security posture of a DFIR platform.
TOTP_REQUIRED=true

# Browser session idle timeout (minutes). Sessions are revoked after this
# many minutes without a request, even though session_ttl_seconds (8h hard
# cap) hasn't elapsed. Tighten for higher-sensitivity deployments; loosen
# only with deliberate tradeoff against stolen-cookie window.
INACTIVITY_TIMEOUT_MINUTES=30

# ── Evidence — chain of custody ──────────────────────────────────────────────
# Master KEK for AES-256-GCM encryption of evidence files at rest.
# REQUIRED — backend refuses to start without it.
# Generate: openssl rand -hex 32
# Treat like a password: rotate by re-encrypting all evidence with the new key
# (no rotation tooling yet; document the manual procedure when needed).
EVIDENCE_KEK=change_me_generate_64_hex_chars

# ── Audit log export signing ─────────────────────────────────────────────────
# Ed25519 seed (32 bytes, base64) used to sign signed-PDF audit log exports.
# REQUIRED — backend refuses to start without it.
# Generate: scripts/generate-audit-key.sh
# The matching public key is exposed at GET /api/version for verification.
AUDIT_SIGNING_KEY=change_me_generate_with_scripts_generate_audit_key_sh
